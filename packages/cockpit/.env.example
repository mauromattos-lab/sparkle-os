# SparkleOS Cockpit — Environment Variables
# Copy to .env and fill in your values

# Server port (default: 3004)
COCKPIT_PORT=3004

# Brain service URL for health checks
BRAIN_URL=http://localhost:3003

# n8n / Zenya integration (Story 4.4)
# N8N_URL: URL of the n8n instance
N8N_URL=http://localhost:5678
# N8N_API_KEY: Optional — enables active workflow count
N8N_API_KEY=

# Node environment
NODE_ENV=development
