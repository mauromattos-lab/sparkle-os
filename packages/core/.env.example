# SparkleOS Core — Environment Variables Template
# Copy this file to .env and fill in the real values.
# NEVER commit .env to the repository.

# --- Supabase (Postgres + Storage) ---
# Found at: https://app.supabase.com → Project Settings → API
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SERVICE_KEY=eyJ...  # service_role key (never expose in frontend)
SUPABASE_ANON_KEY=eyJ...     # anon key (safe for frontend use)

# --- Redis (Coolify VPS) ---
# Context Store hot cache (72h TTL)
REDIS_URL=redis://:[password]@[vps-host]:6379

# --- Anthropic / Claude API ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Internal API ---
# Static token for SparkleOS internal API (Hono)
# Generate with: openssl rand -hex 32
INTERNAL_API_TOKEN=

# --- App ---
PORT=3001
NODE_ENV=development
MONTHLY_BUDGET_USD=570
