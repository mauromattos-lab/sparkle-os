# Zenya — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores

# Porta do servidor (padrão: 3004)
ZENYA_PORT=3004

# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# Master key para criptografia de credenciais dos tenants
# Gerar com: openssl rand -hex 32
ZENYA_MASTER_KEY=

# OpenAI
OPENAI_API_KEY=sk-...

# Chatwoot
CHATWOOT_BASE_URL=https://chatwoot.sparkleai.tech
CHATWOOT_API_TOKEN=   # Chatwoot > Profile Settings > Access Token

# ElevenLabs TTS (opcional — necessário para resposta em áudio)
ELEVENLABS_API_KEY=   # sk_0c95... (ver 1Password)
ELEVENLABS_VOICE_ID=  # ID da voz da Zenya — ElevenLabs > Voices > copiar ID

# Google Calendar OAuth (opcional — necessário para agendamento de clientes)
GOOGLE_CLIENT_ID=65020244042-28elg7596gf8gmks4ie4mr5am72c05co.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET= # GCP Console > Credenciais > OAuth 2.0
