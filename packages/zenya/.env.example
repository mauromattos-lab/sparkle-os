# Zenya — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores

# Porta do servidor (padrão: 3004)
ZENYA_PORT=3004

# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# Master key para criptografia de credenciais dos tenants
# Gerar com: openssl rand -hex 32
ZENYA_MASTER_KEY=

# OpenAI
OPENAI_API_KEY=sk-...

# Chatwoot
CHATWOOT_BASE_URL=https://app.chatwoot.com
CHATWOOT_API_TOKEN=

# ElevenLabs TTS (opcional — necessário para resposta em áudio)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Google Calendar OAuth (opcional — necessário para agendamento)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
