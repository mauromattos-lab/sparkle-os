{
  "name": "@sparkle-os/zenya",
  "version": "0.1.0",
  "private": true,
  "description": "Zenya — Órgão de atendimento WhatsApp nativo do SparkleOS",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "dev": "node --watch --env-file=.env --import tsx/esm src/index.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "preflight": "npx tsx scripts/preflight.ts",
    "deploy": "npm run build && pm2 start ecosystem.config.cjs"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.22",
    "@hono/node-server": "^1.13.0",
    "@supabase/supabase-js": "^2.103.0",
    "ai": "^4.3.16",
    "dotenv": "^17.4.2",
    "googleapis": "^171.4.0",
    "gray-matter": "^4.0.3",
    "hono": "^4.6.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "rimraf": "^6.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
