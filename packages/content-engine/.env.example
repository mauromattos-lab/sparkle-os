# Content Engine — variáveis de ambiente
# Copie para .env e preencha os valores

# Banco de dados (mesmo do @sparkle-os/core)
DATABASE_URL=postgresql://user:password@localhost:5432/sparkle_os

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Modelo usado na pipeline (opcional — default: claude-sonnet-4-6)
CONTENT_ENGINE_MODEL=claude-sonnet-4-6

# Horário de execução em formato cron (opcional — default: 8h diário)
# Timezone: America/Sao_Paulo
CONTENT_SCHEDULE_TIME=0 8 * * *
