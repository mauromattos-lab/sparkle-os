{
  "name": "@sparkle-os/content-engine",
  "version": "0.1.0",
  "private": true,
  "description": "SparkleOS Content Engine — AEO squad scheduler and pipeline runner",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./publisher": {
      "import": "./dist/publication-orchestrator.js",
      "types": "./dist/publication-orchestrator.d.ts"
    }
  },
  "scripts": {
    "dev": "node --watch --env-file=.env --import tsx/esm src/index.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.37.0",
    "@sparkle-os/core": "workspace:*",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@vitest/coverage-v8": "^2.1.0",
    "rimraf": "^6.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
