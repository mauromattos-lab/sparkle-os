# SparkleOS Piloting Interface — Environment Variables Template
# Copy this file to .env.local and fill in the real values.
# NEVER commit .env.local to the repository.

# --- Internal API ---
# URL of the SparkleOS Core API (packages/core)
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- Supabase (for client-side reads) ---
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...  # anon key only — never service_role here
