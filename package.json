{
  "name": "sparkle-os",
  "version": "0.1.0",
  "private": true,
  "description": "SparkleOS — AI-native operating system for Sparkle agency",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
